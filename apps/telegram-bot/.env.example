# Required
SCHED_BOT_TOKEN=TELEGRAM_BOT_TOKEN

# Domains without protocol and without trailing slash
SCHED_BOT_DOMAIN=bot.example.com
SCHED_APP_DOMAIN=app.example.com
SCHED_SERVER_DOMAIN=api.example.com

# Required for image sending (private group chat id with the bot)
SCHED_BOT_IMAGE_DUMP_CHATID=

# Required internal API config
SCHED_SERVER_INTERNAL_API_URL=http://localhost:3000
# Must be at least 64 characters
SCHED_SERVER_INTERNAL_API_SECRET=replace_with_at_least_64_characters_long_internal_api_secret_value

# Optional / defaults shown
SCHED_BOT_ADMIN_TGID=0
SCHED_BOT_ADMIN_CONTACT=[Администратор не задан] # @user
SCHED_BOT_PORT=3002
SCHED_BOT_HOST=0.0.0.0

# Image upload mode: file | url | relay
SCHED_BOT_IMAGE_UPLOAD_MODE=file
# Required when SCHED_BOT_IMAGE_UPLOAD_MODE=relay
SCHED_BOT_IMAGE_RELAY_URL=
SCHED_BOT_IMAGE_RELAY_KEY=
# Optional bypass/protection value for relay
SCHED_BOT_IMAGE_RELAY_PROTECTION_BYPASS=
SCHED_BOT_IMAGE_RELAY_TIMEOUT_MS=10000

# Optional proxy
# If SCHED_BOT_PROXY_TYPE is set, SCHED_BOT_PROXY_URL must be set too
SCHED_BOT_PROXY_URL=
SCHED_BOT_PROXY_TYPE=

# Webhook mode
# true/1 enables webhook mode; otherwise polling is used
SCHED_BOT_USE_WEBHOOK=false
# Must start with "/"
SCHED_BOT_WEBHOOK_PATH=/api/bot/webhook
SCHED_BOT_WEBHOOK_URL=
SCHED_BOT_WEBHOOK_SECRET=

LOG_LEVEL=info
NODE_ENV=production