{
  "name": "@ssau-schedule/telegram-bot",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "prod": "bun dist/index.js",
    "lint": "bunx --bun eslint .",
    "format": "bunx --bun prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@grammyjs/runner": "^2.0.3",
    "@ssau-schedule/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "dotenv": "^17.2.1",
    "elysia": "^1.4.28",
    "grammy": "^1.38.2",
    "pino": "^9.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@ssau-schedule/server": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0"
  }
}