{
  "name": "@ssau-schedule/server",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "db:generate": "bunx --bun prisma generate",
    "db:apply": "bunx --bun prisma migrate dev",
    "db:migrate": "bunx --bun prisma migrate deploy",
    "db:push": "bunx --bun prisma db push",
    "db:studio": "bunx --bun prisma studio",
    "build": "bun css && bun run db:generate && bun build src/index.ts --target bun --outdir ./dist && bun run copy:css",
    "dev": "bun --watch run src/index.ts",
    "prod": "bunx --bun prisma migrate deploy && bun dist/index.js",
    "lint": "bunx --bun eslint .",
    "format": "bunx --bun prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "css": "bunx --bun @tailwindcss/cli -i src/schedule/base.css -o src/generated/timetable.css --minify",
    "css:watch": "bunx --bun @tailwindcss/cli -i src/schedule/base.css -o src/generated/timetable.css --watch --minify",
    "copy:css": "mkdir -p dist/generated && cp src/generated/timetable.css dist/generated/timetable.css",
    "build:container": "docker build -t ghcr.io/arairon/ssau-schedule -f ../../Dockerfile ../.."
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "7",
    "@ssau-schedule/contracts": "workspace:*",
    "@ssau-schedule/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "@tma.js/init-data-node": "^2.0.5",
    "ajv-ts": "^0.9.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.1",
    "elysia": "^1.4.28",
    "grammy": "^1.38.2",
    "ics": "^3.8.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "7",
    "puppeteer": "^24.19.0",
    "toad-scheduler": "^3.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@ssau-schedule/telegram-bot": "workspace:*",
    "@tailwindcss/cli": "^4.1.12",
    "@types/bun": "^1.3.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0"
  }
}