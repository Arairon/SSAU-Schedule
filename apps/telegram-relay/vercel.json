{
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30,
      "includeFiles": [
        "node_modules/@ssau-schedule/contracts/**/*",
        "../../packages/contracts/**/*"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/healthz",
      "destination": "/api/healthz"
    },
    {
      "source": "/send/:path*",
      "destination": "/api/send/:path*"
    }
  ]
}